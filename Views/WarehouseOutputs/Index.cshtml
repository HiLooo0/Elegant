@model IEnumerable<Elegant.Models.WarehouseOutput>

@{
    ViewBag.Title = "Видаткові накладні";
}

<h2>Видаткові накладні</h2>

<p>
    @Html.ActionLink("Створити нову накладну", "Create", null, new { @class = "btn btn-primary btn-create" })
</p>
<table class="table table-hover">
    <tr>
        <th>
            Номер
        </th>
        <th>
            @Html.DisplayNameFor(model => model.OutputDate)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Destination)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id)
            </td>
            <td>
                @item.OutputDate.ToString("dd.MM.yyyy")
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Destination)
            </td>
            <td class="action-links">
                @Html.ActionLink("Наповнити / Деталі", "Details", new { id = item.Id }) |
                @Html.ActionLink("Видалити", "Delete", new { id = item.Id })
            </td>
        </tr>
    }

</table>