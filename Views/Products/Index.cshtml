@* Змінюємо тип моделі, щоб вона відповідала тому, що передає контролер *@
@model PagedList.IPagedList<Elegant.Models.Product>
@using PagedList.Mvc;

@{
    ViewBag.Title = "Список меблів";
}

<h2>Список меблів</h2>

<p>
    @Html.ActionLink("Додати нові меблі", "Create", null, new { @class = "btn btn-primary btn-create" })
</p>
<table class="table table-hover">
    <tr>
        <th>Фото</th>
        <th>
            @Html.DisplayNameFor(model => model.First().Category.Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.First().Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.First().Article)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.First().Price)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.First().Stock)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @if (!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl" alt="@item.Name" style="width:50px; height:60px; object-fit:cover; border-radius:4px;" />
                }
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Article)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
            <td>
                @if (item.Stock <= 3)
                {
                    <span class="text-danger">@item.Stock</span>
                }
                else
                {
                    @item.Stock
                }
            </td>
            <td>
                @Html.ActionLink("Редагувати", "Edit", new { id = item.Id }) |
                @Html.ActionLink("Деталі", "Details", new { id = item.Id }) |
                @Html.ActionLink("Видалити", "Delete", new { id = item.Id })
            </td>
        </tr>
    }

</table>

<!-- ДОДАЄМО НАВІГАЦІЮ ПО СТОРІНКАХ -->
<br />
Сторінка @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) з @Model.PageCount

@Html.PagedListPager(Model, page => Url.Action("Index", new { page }))