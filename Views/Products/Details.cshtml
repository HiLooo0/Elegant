@model Elegant.Models.Product
@{ ViewBag.Title = "Деталі товару"; }

<h2>Деталі товару "@Model.Name"</h2>
<hr />
<div>
    <dl class="dl-horizontal">
        <dt>@Html.DisplayNameFor(model => model.Category.Name)</dt>
        <dd>@Html.DisplayFor(model => model.Category.Name)</dd>

        <dt>@Html.DisplayNameFor(model => model.Name)</dt>
        <dd>@Html.DisplayFor(model => model.Name)</dd>

        <dt>@Html.DisplayNameFor(model => model.Article)</dt>
        <dd>@Html.DisplayFor(model => model.Article)</dd>

        <dt>@Html.DisplayNameFor(model => model.Description)</dt>
        <dd>@Html.DisplayFor(model => model.Description)</dd>

        <dt>@Html.DisplayNameFor(model => model.Price)</dt>
        <dd>@Html.DisplayFor(model => model.Price)</dd>

        <dt>@Html.DisplayNameFor(model => model.OldPrice)</dt>
        <dd>@(Model.OldPrice.HasValue ? Model.OldPrice.Value.ToString("N2") : "-")</dd>

        <dt>@Html.DisplayNameFor(model => model.Stock)</dt>
        <dd>@Html.DisplayFor(model => model.Stock)</dd>

        <dt>@Html.DisplayNameFor(model => model.IsFeatured)</dt>
        <dd>@(Model.IsFeatured ? "Так" : "Ні")</dd>

        <dt>@Html.DisplayNameFor(model => model.ImageUrl)</dt>
        <dd>
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" style="max-width:200px; border-radius:6px;" />
            }
            else
            {
                @:-
            }
        </dd>
    </dl>
</div>
<p>
    @Html.ActionLink("Редагувати", "Edit", new { id = Model.Id }) |
    @Html.ActionLink("Назад до списку", "Index")
</p>