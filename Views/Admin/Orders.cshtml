@model IEnumerable<Elegant.Models.Order>
@{
    ViewBag.Title = "Замовлення";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header" style="margin-top: 40px;">
    <h2>Замовлення з сайту</h2>
</div>

<p>
    @Html.ActionLink("Назад до панелі", "Index", "Admin", null, new { @class = "btn btn-default" })
</p>

@if (!Model.Any())
{
    <p>Замовлень ще немає.</p>
}
else
{
    var statuses = new[] { "Нове", "В обробці", "Відправлено", "Скасовано" };

    <table class="table table-hover">
        <thead>
            <tr>
                <th>№</th>
                <th>Дата</th>
                <th>Клієнт</th>
                <th>Телефон</th>
                <th>Адреса</th>
                <th>Товари</th>
                <th>Сума</th>
                <th>Статус</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@order.CustomerName</td>
                    <td>@order.Phone</td>
                    <td>@order.Address</td>
                    <td>
                        @if (order.OrderItems != null)
                        {
                            foreach (var item in order.OrderItems)
                            {
                                <div>@(item.Product != null ? item.Product.Name : "—") &times; @item.Quantity</div>
                            }
                        }
                    </td>
                    <td>@order.TotalPrice.ToString("N0") ₴</td>
                    <td>
                        @using (Html.BeginForm("UpdateOrderStatus", "Admin", FormMethod.Post, new { style = "display:flex; gap:6px;" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@order.Id" />
                            <select name="status" class="form-control" style="display:inline-block; width:auto;">
                                @foreach (var s in statuses)
                                {
                                    if (s == order.Status)
                                    {
                                        <option value="@s" selected="selected">@s</option>
                                    }
                                    else
                                    {
                                        <option value="@s">@s</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm">Зберегти</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
